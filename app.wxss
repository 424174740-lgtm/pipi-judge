/**
 * 全局样式
 */
@import './styles/variables.wxss';
@import './styles/animations.wxss';

/* 页面基础 */
page {
  background-color: var(--bg);
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', 'PingFang SC', 'Microsoft YaHei', sans-serif;
  color: var(--text-dark);
  font-size: var(--font-size-base);
  line-height: 1.6;
  box-sizing: border-box;
}

/* 通用按钮重置 */
button {
  border: none;
  outline: none;
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: inherit;
  font-size: inherit;
}

button::after {
  border: none;
}

/* 通用卡片 */
.card {
  background: var(--card-bg);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 30rpx;
  margin-bottom: 24rpx;
}

/* 通用容器 */
.page {
  min-height: 100vh;
  padding: 30rpx;
  box-sizing: border-box;
}

/* 通用标题 */
.section-title {
  font-size: var(--font-size-lg);
  font-weight: 600;
  color: var(--primary-dark);
  margin-bottom: 16rpx;
}

/* 通用正文 */
.body-text {
  font-size: var(--font-size-base);
  color: var(--text-dark);
  line-height: 1.7;
  word-break: break-word;
}

/* 通用次要文本 */
.text-light {
  font-size: var(--font-size-sm);
  color: var(--text-light);
}

/* 禁用状态 */
.disabled {
  opacity: 0.5;
  pointer-events: none;
}
