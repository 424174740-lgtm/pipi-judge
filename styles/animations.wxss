/* 猫猫旋转动画 */
@keyframes catSpin {
  0% { transform: rotate(0deg); }
  25% { transform: rotate(10deg); }
  75% { transform: rotate(-10deg); }
  100% { transform: rotate(0deg); }
}

.cat-spin {
  animation: catSpin 1.5s ease-in-out infinite;
  display: inline-block;
}

/* 猫猫呼吸动画 */
@keyframes catBreathe {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

.cat-breathe {
  animation: catBreathe 2s ease-in-out infinite;
}

/* 淡入动画 */
@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.fade-in-up {
  animation: fadeInUp 0.5s ease-out both;
}

/* 进度条条纹动画 */
@keyframes progressStripe {
  from { background-position: 0 0; }
  to { background-position: 40rpx 0; }
}

/* 闪烁动画 */
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

.blink {
  animation: blink 1s ease-in-out infinite;
}

/* 卡片入场-从左侧滑入 */
@keyframes slideInLeft {
  from {
    opacity: 0;
    transform: translateX(-60rpx);
  }
  to {
    opacity: 1;
    transform: translateX(0);
  }
}

.slide-in-left {
  animation: slideInLeft 0.4s ease-out both;
}

/* 跳动 */
@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-12rpx); }
}

.bounce {
  animation: bounce 1s ease-in-out infinite;
}

/* 法槌敲击 */
@keyframes hammerHit {
  0% { transform: rotate(0deg) scale(1); }
  30% { transform: rotate(-20deg) scale(1.1); }
  60% { transform: rotate(10deg) scale(0.95); }
  100% { transform: rotate(0deg) scale(1); }
}

.hammer-hit {
  animation: hammerHit 0.6s ease-out;
}