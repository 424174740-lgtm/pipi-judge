/* 首页样式 */
.index-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-left: 14rpx;
  padding-right: 14rpx;
}

/* 头部区域 */
.hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx 0 28rpx;
}

.cat-avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #FFFFFF;
  border: 5rpx solid #FFFFFF;
  box-shadow: 0 4rpx 24rpx rgba(255, 140, 0, 0.25), 0 0 0 3rpx rgba(255, 140, 0, 0.1);
  margin-bottom: 18rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 700;
  color: #FF8C00;
  margin-bottom: 8rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  color: #999999;
}

/* ========== 模式切换开关 ========== */
.mode-toggle {
  width: 100%;
  display: flex;
  background: #F0F0F0;
  border-radius: 24rpx;
  padding: 6rpx;
  margin-bottom: 28rpx;
}

.mode-option {
  flex: 1;
  text-align: center;
  padding: 22rpx 0;
  border-radius: 20rpx;
  font-size: 28rpx;
  font-weight: 500;
  color: #999999;
  transition: all 0.2s;
}

.mode-active {
  background: linear-gradient(135deg, #FF8C00, #FFA940);
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 4rpx 12rpx rgba(255, 140, 0, 0.2);
}

.mode-hint {
  font-size: 22rpx;
  opacity: 0.7;
  margin-left: 4rpx;
}

.mode-active .mode-hint {
  opacity: 0.85;
}

/* ========== 输入卡片（单人模式） ========== */
.input-card {
  width: 100%;
  box-sizing: border-box;
}

.input-label {
  padding: 0 24rpx;
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 16rpx;
}

.input-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: var(--radius-sm);
  font-size: var(--font-size-base);
  color: var(--text-dark);
  line-height: 1.7;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

/* 单人模式输入框：横向长方形，固定高度 */
.input-card .input-textarea {
  height: 280rpx;
  min-height: 280rpx;
  padding: 24rpx;
  font-size: 30rpx;
  line-height: 1.7;
}

/* 输入框上方常驻引导提示 */
.input-hint {
  padding: 0 24rpx;
  font-size: 24rpx;
  color: #BBBBBB;
  margin-bottom: 14rpx;
  line-height: 1.5;
}

/* 单人模式卡片左右留安全边距 */
.input-card.card {
  padding-left: 16rpx;
  padding-right: 16rpx;
}

/* 字数超限预警 */
.textarea-warn {
  border-color: #FF8C00 !important;
  background: #FFFCF5 !important;
}

.char-warn {
  color: #FF8C00 !important;
}

.char-hint-text {
  font-size: 22rpx;
  margin-right: 8rpx;
}

.input-textarea:focus {
  border-color: var(--primary-light);
}

.char-count {
  text-align: right;
  font-size: var(--font-size-sm);
  color: var(--text-light);
  margin-top: 8rpx;
}

/* 单人模式下字数统计与标签对齐 */
.input-card .char-count {
  padding: 0 24rpx;
}

/* ========== 截图上传（多模态） ========== */
.ocr-entry {
  width: 100%;
  margin-bottom: 16rpx;
}

.ocr-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 22rpx 0;
  background: #FAFAFA;
  border: 2rpx dashed #DDDDDD;
  border-radius: 20rpx;
  transition: all 0.2s;
}

.ocr-btn:active {
  background: #F0F0F0;
  border-color: #FF8C00;
}

.ocr-icon {
  font-size: 36rpx;
}

.ocr-text {
  font-size: 28rpx;
  color: #999999;
}

/* 截图上传加载中 */
.ocr-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  padding: 22rpx 0;
  margin-bottom: 16rpx;
}

.ocr-spinner {
  font-size: 36rpx;
  animation: ocr-pulse 1.2s ease-in-out infinite;
}

@keyframes ocr-pulse {
  0%, 100% { transform: scale(1); opacity: 1; }
  50% { transform: scale(1.15); opacity: 0.6; }
}

/* 截图缩略图 */
.ocr-thumb-wrap {
  position: relative;
  display: inline-block;
  margin-bottom: 16rpx;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.ocr-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  display: block;
}

.ocr-thumb-del {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: rgba(0, 0, 0, 0.6);
  color: #FFFFFF;
  border-radius: 50%;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 双方陈述模式 ========== */
.dual-section {
  width: 100%;
}

/* 填写进度条 */
.dual-progress-wrap {
  margin-bottom: 28rpx;
  padding: 0 10rpx;
}

.dual-progress-bar {
  width: 100%;
  height: 10rpx;
  background: #F0F0F0;
  border-radius: 5rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.dual-progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #FF8C00, #FFA940);
  border-radius: 5rpx;
  transition: width 0.3s ease;
}

.dual-progress-label {
  font-size: 24rpx;
  color: #BBBBBB;
  text-align: center;
}

/* 当事人卡片 */
.party-card {
  width: 100%;
  background: #FFFFFF;
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  margin-bottom: 24rpx;
  overflow: visible;
}

/* 卡片头部 — 吸顶固定 */
.party-header {
  padding: 22rpx 24rpx;
  display: flex;
  align-items: center;
  gap: 14rpx;
  position: sticky;
  top: 0;
  z-index: 10;
}

.party-a-header {
  background: linear-gradient(135deg, #FFF5E6, #FFEEDB);
}

.party-b-header {
  background: linear-gradient(135deg, #EEF5FF, #DDEBFF);
}

/* A/B 徽章 */
.party-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  font-size: 28rpx;
  font-weight: 700;
  color: #FFFFFF;
}

.party-badge-a {
  background: #FF8C00;
}

.party-badge-b {
  background: #5B8FF9;
}

.party-label {
  font-size: var(--font-size-base);
  font-weight: 500;
  color: var(--text-gray);
}

/* 卡片内容区 */
.party-body {
  padding: 24rpx;
}

.field-group {
  margin-bottom: 24rpx;
}

.field-group:last-child {
  margin-bottom: 0;
}

.field-label {
  font-size: var(--font-size-base);
  font-weight: 600;
  color: var(--text-dark);
  margin-bottom: 10rpx;
}

/* 双方模式输入框：横向长方形，带主题呼应颜色 */
.textarea-dual {
  width: 100%;
  height: 240rpx;
  min-height: 240rpx;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  font-size: 28rpx;
  color: #333333;
  line-height: 1.7;
  box-sizing: border-box;
  border: 2rpx solid transparent;
  transition: border-color 0.2s;
}

.textarea-dual:focus {
  border-color: #FFB347;
}

/* 双方模式字数统计与输入框对齐 */
.field-group .char-count {
  padding: 0 4rpx;
  margin-top: 6rpx;
}

/* ========== 提交按钮 ========== */
.submit-btn {
  width: 100%;
  padding: 26rpx 0;
  background: linear-gradient(135deg, #FF8C00, #FFA940);
  border-radius: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  color: #FFFFFF;
  -webkit-text-fill-color: #FFFFFF;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1;
  box-shadow: 0 4rpx 16rpx rgba(255, 140, 0, 0.3);
  transition: all 0.2s;
  margin-bottom: 30rpx;
}

.submit-btn-press {
  transform: scale(0.97);
  box-shadow: 0 2rpx 8rpx rgba(255, 140, 0, 0.2);
}

.btn-disabled {
  background: #E0E0E0 !important;
  box-shadow: none !important;
  color: #999999 !important;
  -webkit-text-fill-color: #999999 !important;
}

/* 底部说明 */
.footer-text {
  font-size: 24rpx;
  color: #BBBBBB;
  padding: 30rpx 0 50rpx;
  text-align: center;
  letter-spacing: 2rpx;
}
