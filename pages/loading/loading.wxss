/* Loading 页样式 */
.loading-page {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 80vh;
}

/* 猫猫动画区域 */
.cat-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 60rpx;
}

.cat-circle {
  width: 200rpx;
  height: 200rpx;
  background: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 40rpx rgba(255, 140, 0, 0.15);
  margin-bottom: 30rpx;
  overflow: hidden;
  border: 6rpx solid #FFFFFF;
}

.cat-avatar-loading {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
}

.cat-spin {
  animation: gentle-spin 3s ease-in-out infinite;
}

@keyframes gentle-spin {
  0% { transform: rotate(0deg); }
  25% { transform: rotate(-8deg); }
  75% { transform: rotate(8deg); }
  100% { transform: rotate(0deg); }
}

.thought-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  min-height: 50rpx;
}

.cat-thought {
  font-size: var(--font-size-lg);
  font-weight: 500;
  color: var(--primary-dark);
  text-align: center;
  transition: opacity 0.3s;
}

.gavel-icon {
  font-size: 48rpx;
  display: inline-block;
  animation: stamp-paw 1.5s ease-in-out infinite;
  transform-origin: 50% 80%;
}

@keyframes stamp-paw {
  0%   { transform: translateY(0) scale(1); }
  15%  { transform: translateY(-28rpx) scale(0.9) rotate(-15deg); }
  35%  { transform: translateY(0) scale(1.15) rotate(5deg); }
  50%  { transform: translateY(0) scale(1) rotate(0deg); }
  100% { transform: translateY(0) scale(1) rotate(0deg); }
}

/* 进度条 */
.progress-section {
  width: 80%;
  margin-bottom: 40rpx;
}

.progress-track {
  width: 100%;
  height: 12rpx;
  background: #F0E0CC;
  border-radius: 6rpx;
  overflow: hidden;
  margin-bottom: 16rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--primary), var(--primary-light));
  border-radius: 6rpx;
  transition: width 0.5s ease-out;
}

.progress-label {
  text-align: center;
}

.progress-text {
  font-size: var(--font-size-sm);
  color: var(--text-light);
}

/* 装饰文案区域 */
.decorative-text {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 80rpx;
  min-height: 120rpx;
}

.deco-line {
  font-size: var(--font-size-sm);
  color: var(--text-light);
  opacity: 0;
  position: absolute;
  transition: opacity 0.5s ease;
}

.deco-active {
  opacity: 1;
  position: relative;
}

/* 取消按钮 */
.cancel-btn {
  width: 240rpx;
  height: 72rpx;
  background: transparent;
  border: 2rpx solid var(--border);
  border-radius: 36rpx;
  font-size: var(--font-size-base);
  color: var(--text-gray);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cancel-btn:active {
  background: rgba(0, 0, 0, 0.03);
}
